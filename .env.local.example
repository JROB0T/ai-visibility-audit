# Supabase - get these from your Supabase project dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# App URL - change this to your deployed URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin trigger token for /api/internal/free-scan/admin-trigger.
# Generate with: openssl rand -hex 24
# Required for sales to fire one-off free scans without going through the
# public form. Endpoint refuses every call when this is unset.
ADMIN_TRIGGER_TOKEN=

# ============================================================
# Email delivery (Resend)
# ============================================================
# Get your API key from https://resend.com/api-keys
# Free tier covers 3,000 emails/month at 100/day — plenty for early use.
# Sends are best-effort: if RESEND_API_KEY is unset, scans still succeed
# but no notification email goes out (logged as [EMAIL_ERROR]).
RESEND_API_KEY=

# From-address for transactional emails. Two options:
#   1. Resend's onboarding sender — quickest start, mediocre deliverability:
#        EMAIL_FROM="AI Visibility Audit <onboarding@resend.dev>"
#   2. A verified domain you own — recommended for production:
#        EMAIL_FROM="AI Visibility Audit <hello@yourdomain.com>"
# Verify a domain at https://resend.com/domains before using #2.
EMAIL_FROM=

# Optional reply-to. When customers hit reply, this is where it goes.
# Leave blank to default to the From address.
EMAIL_REPLY_TO=
